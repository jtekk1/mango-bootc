{
    "label" : "lock",
    "action" : "swaylock -C ~/.config/swaylock/config",
    "text" : "  Lock   ",
    "keybind" : "l"
}

{
    "label" : "logout",
    "action" : "loginctl terminate-user $USER",
    "text" : " Logout  ",
    "keybind" : "m"
}

{
    "label" : "shutdown",
    "action" : "poweroff",
    "text" : "Shutdown ",
    "keybind" : "d"
}

{
    "label" : "reboot",
    "action" : "reboot",
    "text" : " Reboot  ",
    "keybind" : "r"
}

{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : " Suspend ",
    "keybind" : "s"
}
